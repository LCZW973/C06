public abstract class  Maeclasse  implements Comparable <Maeclasse>
{
    protected String nome;
    protected int numero;

    public Maeclasse(String nome , int numero)
    {
       this.nome=nome;
       this.numero=numero;
    }

    @Override
    public int compareTo(Maeclasse o)
    {
        if(this.numero>o.numero)
        {
            return -1;
        }
        if(this.numero<o.numero)
        {
            return 1;
        }

        return  0 ;
    }
}
